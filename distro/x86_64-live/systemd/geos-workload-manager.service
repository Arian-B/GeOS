[Unit]
Description=GeOS Workload Manager
After=geos-energy-controller.service
Requires=geos-energy-controller.service

[Service]
Type=simple
WorkingDirectory=/opt/geos
Environment=PYTHONPATH=/opt/geos
ExecStart=/opt/geos/.venv/bin/python -m workloads.workload_manager
Restart=always
RestartSec=2

[Install]
WantedBy=geos-demo.target
