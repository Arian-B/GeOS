#!/bin/bash
set -euo pipefail

echo "== GeOS Demo Health =="

echo "-- Process checks --"
for module in \
  core_os.boot_manager \
  core_os.energy_controller \
  workloads.workload_manager \
  telemetry.collector \
  core_os.resource_daemon \
  core_os.update_watcher \
  interface.workflow_server \
  interface.repl_server \
  telemetry.metrics_server
do
  if pgrep -f "$module" >/dev/null 2>&1; then
    echo "[OK] $module"
  else
    echo "[MISS] $module"
  fi
done

echo "-- Local endpoints --"
for url in \
  http://127.0.0.1:8080/status \
  http://127.0.0.1:8090/metrics
do
  if command -v curl >/dev/null 2>&1 && curl -fsS "$url" >/dev/null 2>&1; then
    echo "[OK] $url"
  else
    echo "[MISS] $url"
  fi
done

echo "-- GUI log --"
if [[ -f /opt/geos/logs/gui-session.log ]]; then
  tail -n 20 /opt/geos/logs/gui-session.log || true
else
  echo "No gui-session.log yet"
fi
